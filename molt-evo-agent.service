[Unit]
Description=molt_evo local persistence helper
After=network.target

[Service]
Type=simple
WorkingDirectory=${MOLT_EVO_WORKSPACE:-/root/.openclaw/workspace}
ExecStart=/bin/bash -lc 'while true; do python3 ${MOLT_EVO_WORKSPACE:-/root/.openclaw/workspace}/molt_evo_memory.py init >/dev/null; sleep 300; done'
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
